{
  "name": "comunia",
  "version": "0.1.2",
  "description": "Open-source AI community manager — events, profiling, learning. Deploy with docker compose up.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "comunia": "dist/bin/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "drizzle.config.ts",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "community",
    "ai",
    "telegram",
    "whatsapp",
    "events",
    "agent",
    "llm",
    "claude",
    "openai",
    "community-management",
    "chatbot"
  ],
  "author": "Emiliano Velazquez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/farosud/comunia.git"
  },
  "homepage": "https://github.com/farosud/comunia",
  "bugs": {
    "url": "https://github.com/farosud/comunia/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.1.0",
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "hono": "^4.12.7",
    "node-cron": "^4.2.1",
    "openai": "^6.27.0",
    "p-queue": "^9.1.0",
    "zod": "^4.3.6"
  }
}
