# === LLM ===
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...          # OpenRouter API key (get one at https://openrouter.ai/keys)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4  # Model to use via OpenRouter (see https://openrouter.ai/models)
# OLLAMA_URL=http://localhost:11434

# === Telegram ===
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_GROUP_CHAT_ID=-100...

# === WhatsApp (Cloud API = official/supported, baileys = experimental) ===
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=cloud_api
# WHATSAPP_CLOUD_API_TOKEN=...
# WHATSAPP_PHONE_NUMBER_ID=...
# WHATSAPP_VERIFY_TOKEN=...
# WHATSAPP_GROUP_ID=...

# === Community ===
COMMUNITY_NAME=My Community
COMMUNITY_LANGUAGE=es-AR
COMMUNITY_TYPE=local
COMMUNITY_LOCATION=Buenos Aires, AR
ADMIN_USER_IDS=

# === Scheduler ===
REMINDER_HOURS_BEFORE=48,2
FEEDBACK_DELAY_HOURS=24
DIGEST_CRON=0 10 * * 1
REFLECTION_CRON=0 3 * * *
VENUE_RESEARCH_CRON=0 9 * * 3
EVENT_IDEATION_CRON=0 10 * * 1
SUBGROUP_ANALYSIS_CRON=0 4 * * 0

# === Dashboard ===
DASHBOARD_PORT=3000
DASHBOARD_SECRET=change-me-to-a-random-string

# === Limits ===
LLM_MAX_CONCURRENT=10
LLM_MAX_PER_MINUTE=30
